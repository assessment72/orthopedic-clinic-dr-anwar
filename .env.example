# Demo Mode (disable in production)
DEMO=false

# ===================================
# Protocol Server Configuration
# ===================================

# Enable/disable protocol servers (set to false to disable)
PROTOCOL_SERVERS_ENABLED=true

# HL7 v2 Server Configuration
HL7_SERVER_ENABLED=true
HL7_SERVER_PORT=2575
HL7_SERVER_HOST=0.0.0.0
HL7_CONNECTION_TIMEOUT=300000
HL7_MESSAGE_TIMEOUT=30000
HL7_MAX_CONNECTIONS=100
HL7_AUTO_ACK=true

# ASTM E1381/E1394 Server Configuration
ASTM_SERVER_ENABLED=true
ASTM_SERVER_PORT=5000
ASTM_SERVER_HOST=0.0.0.0
ASTM_CONNECTION_TIMEOUT=300000
ASTM_FRAME_TIMEOUT=15000
ASTM_MAX_CONNECTIONS=50
ASTM_RETRY_COUNT=3
ASTM_CHECKSUM_ENABLED=true

# FHIR R4 Endpoints (served via Next.js API, always enabled)
# Endpoints:
#   POST /api/fhir/DiagnosticReport
#   POST /api/fhir/Observation
#   POST /api/fhir/Bundle

